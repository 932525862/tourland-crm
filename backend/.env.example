# Server
NODE_ENV=production
PORT=4000
CORS_ORIGIN=https://your-frontend-domain.com,http://localhost:5173

# Database
DATABASE_URL=postgresql://crm:crm@localhost:5432/agency_crm?schema=public

# Redis (BullMQ + WS adapter)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change_me_super_long_random_string
JWT_EXPIRES_IN=7d

# Bootstrap director (created on first run if no director exists)
DIRECTOR_NAME=Direktor
DIRECTOR_LOGIN=admin
DIRECTOR_PASSWORD=admin123

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_REMINDER_LEAD_MINUTES=60
